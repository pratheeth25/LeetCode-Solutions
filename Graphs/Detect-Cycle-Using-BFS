import java.util.*;

class Solution {

    public boolean isCycle(int V, int[][] edges) {

        // Build adjacency list
        ArrayList<ArrayList<Integer>> adj = new ArrayList<>();

        for (int i = 0; i < V; i++) {
            adj.add(new ArrayList<>());
        }

        // Add edges (undirected)
        for (int[] edge : edges) {

            int u = edge[0];
            int v = edge[1];

            adj.get(u).add(v);
            adj.get(v).add(u);
        }

        boolean[] visited = new boolean[V];

        // Check every component
        for (int vertex = 0; vertex < V; vertex++) {

            if (!visited[vertex]) {

                if (bfsCycleCheck(vertex, adj, visited)) {
                    return true;
                }
            }
        }

        return false;
    }

    // BFS function
    static boolean bfsCycleCheck(int startVertex,
                                 ArrayList<ArrayList<Integer>> adj,
                                 boolean[] visited) {

        Queue<int[]> queue = new LinkedList<>();

        // {currentNode, parentNode}
        queue.add(new int[]{startVertex, -1});
        visited[startVertex] = true;

        while (!queue.isEmpty()) {

            int[] current = queue.poll();

            int currentNode = current[0];
            int parentNode = current[1];

            // Traverse neighbors
            for (int neighbor : adj.get(currentNode)) {

                // If not visited → visit
                if (!visited[neighbor]) {

                    visited[neighbor] = true;
                    queue.add(new int[]{neighbor, currentNode});
                }

                // If visited and not parent → cycle
                else if (neighbor != parentNode) {
                    return true;
                }
            }
        }

        return false;
    }
}

Here we use parent array 
So when we visit a node and neighbour is also visited 
but for given nodes parent is not neighbour so 
Node should have come from other path . 
So cycle is detected.
