class Solution {
    public boolean isPalindrome(String s) {
        String temp = s.toLowerCase();
        
        temp = temp.replaceAll("[^a-zA-Z0-9]","");
        char[] ch = temp.toCharArray();
        int i = 0;
        int j = ch.length-1;
        while(i < j){
            if(ch[i] != ch[j]){
                return false;
            }else{
                i++;
                j--;
            }
            
        }
        return true;
    }
}
