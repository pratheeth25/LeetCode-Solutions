class Solution {
    public int subarraySum(int[] nums, int k) {
        int n = nums.length;
        int[] prefix = new int[n];
        HashMap<Integer,Integer> map = new HashMap<>();
        map.put(0,1);
        int ans = 0;
        for(int i=0;i<n;i++){
            if(i == 0){
                prefix[0] = nums[i];
            }else{
                prefix[i] = prefix[i-1] + nums[i];
            }
            int diff = prefix[i] - k;
            if(map.containsKey(diff)){
                ans += map.get(diff);
            }
            map.put(prefix[i],map.getOrDefault(prefix[i],0)+1);
        }
        return ans;
    }
}

