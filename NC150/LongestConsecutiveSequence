class Solution {
    public int longestConsecutive(int[] nums) {
        HashSet<Integer> set = new HashSet<>();
        for(int a:nums){
            set.add(a);
        }
        int longest = 0;
        for(int a:set){
            if(!set.contains(a-1)){
                int curr = a;
                int sum = 1;
                while(set.contains(curr+1)){
                    curr++;
                    sum++;
                }
                longest = Math.max(sum,longest);
            }
        }
        return longest;
    }
}
